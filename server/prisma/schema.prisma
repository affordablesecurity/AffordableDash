generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  DISPATCHER
  TECHNICIAN
}

enum JobStatus {
  LEAD
  SCHEDULED
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
  CONVERTED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  username     String           @unique
  name         String
  phone        String?
  passwordHash String
  role         UserRole         @default(DISPATCHER)
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  memberships      UserMembership[]
  locationApiKeys LocationApiKey[]
}

model Organization {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  locations   Location[]
  memberships UserMembership[]
  integrations IntegrationCredential[]
}

model Location {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  displayName    String?
  slug           String
  phone          String?
  street1        String?
  street2        String?
  city           String?
  state          String?
  postalCode     String?
  timezone       String           @default("America/Phoenix")
  companyColor   String           @default("#26aef2")
  website        String?
  industry       String?
  description    String?
  termsOfService String?
  logoName       String?
  invoiceSettings Json?
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    UserMembership[]
  customers      Customer[]
  technicians    Technician[]
  jobs           Job[]
  events         Event[]
  estimates      Estimate[]
  invoices       Invoice[]
  messages       Message[]
  apiKeys        LocationApiKey[]
  integrations   IntegrationCredential[]
  crmOptions     CrmOption[]
  jobTemplates   JobTemplate[]
  servicePlanTemplates ServicePlanTemplate[]
  priceBookCategories PriceBookCategory[]
  priceBookItems      PriceBookItem[]

  @@unique([organizationId, slug])
}

model LocationApiKey {
  id          String    @id @default(cuid())
  locationId  String
  name        String
  tokenPrefix String    @unique
  tokenHash   String    @unique
  tokenCipher String?
  scopes      String[]  @default(["customers:read", "jobs:read"])
  active      Boolean   @default(true)
  createdById String?
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

model UserMembership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  locationId     String?
  role           UserRole     @default(DISPATCHER)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location       Location?    @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, locationId])
}

model Customer {
  id                 String    @id @default(cuid())
  locationId         String
  firstName          String
  lastName           String
  companyName        String?
  email              String?
  phone              String
  alternatePhone     String?
  additionalEmails   String[]  @default([])
  additionalPhones   Json?
  source             String?
  tags               String[]  @default([])
  housecallProId     String?   @unique
  notes              String?
  communicationPrefs Json?
  attachments        String[]  @default([])
  paymentMethodNote  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  addresses          Address[]
  jobs               Job[]
  estimates          Estimate[]
  invoices           Invoice[]
  messages           Message[]
  privateNotes       CustomerNote[]
  location           Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  author     String   @default("Office")
  content    String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Address {
  id          String   @id @default(cuid())
  customerId  String
  label       String   @default("Service")
  street1     String
  street2     String?
  city        String
  state       String
  postalCode  String
  latitude    Decimal?
  longitude   Decimal?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs        Job[]
  estimates   Estimate[]
}

model Technician {
  id             String   @id @default(cuid())
  userId         String?
  locationId     String
  name           String
  email          String?
  phone          String
  color          String   @default("#2563eb")
  employmentType String   @default("employee")
  role           String   @default("OUTSIDE_FIELD_TECH")
  fieldTech      Boolean  @default(true)
  permissions    String[] @default(["jobs:write", "customers:write", "invoices:write"])
  active         Boolean  @default(true)
  housecallProId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  jobs           Job[]
  events         Event[]
  estimates      Estimate[]
  location       Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, userId])
}

model Job {
  id             String        @id @default(cuid())
  jobNumber      Int           @unique @default(autoincrement())
  locationId     String
  customerId     String
  addressId      String?
  technicianId   String?
  title          String
  jobType        String
  leadSource     String?
  tags           String[]      @default([])
  status         JobStatus     @default(LEAD)
  priority       String        @default("normal")
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  completedAt    DateTime?
  description    String?
  internalNotes  String?
  attachments    String[]       @default([])
  housecallProId String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customer       Customer      @relation(fields: [customerId], references: [id])
  address        Address?      @relation(fields: [addressId], references: [id])
  technician     Technician?   @relation(fields: [technicianId], references: [id])
  location       Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  notes          JobNote[]
  lineItems      JobLineItem[]
  invoices       Invoice[]
  convertedFromEstimate Estimate? @relation("EstimateConvertedJob")
}

model Event {
  id             String      @id @default(cuid())
  locationId     String
  technicianId   String?
  name           String
  notes          String?
  eventLocation  String?
  latitude       Decimal?
  longitude      Decimal?
  scheduledStart DateTime
  scheduledEnd   DateTime
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  location       Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  technician     Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  @@index([locationId, scheduledStart])
  @@index([technicianId])
}

model Estimate {
  id                String         @id @default(cuid())
  estimateNumber    Int            @unique @default(autoincrement())
  locationId        String
  customerId        String
  addressId         String?
  technicianId      String?
  convertedJobId    String?        @unique
  title             String
  jobType           String
  leadSource        String?
  tags              String[]       @default([])
  status            EstimateStatus @default(DRAFT)
  scheduledStart    DateTime?
  scheduledEnd      DateTime?
  description       String?
  internalNotes     String?
  approvalSignature String?
  approvalName      String?
  approvedAt        DateTime?
  declinedAt        DateTime?
  attachments       String[]       @default([])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  location          Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  customer          Customer       @relation(fields: [customerId], references: [id])
  address           Address?       @relation(fields: [addressId], references: [id], onDelete: SetNull)
  technician        Technician?    @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  convertedJob      Job?           @relation("EstimateConvertedJob", fields: [convertedJobId], references: [id], onDelete: SetNull)
  lineItems         EstimateLineItem[]
}

model EstimateLineItem {
  id          String   @id @default(cuid())
  estimateId  String
  category    String   @default("service")
  name        String
  description String?
  quantity    Decimal  @default(1)
  unitPrice   Int      @default(0)
  unitCost    Int      @default(0)
  taxable     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
}

model CrmOption {
  id         String   @id @default(cuid())
  locationId String
  kind       String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, kind, name])
  @@index([locationId, kind])
}

model JobTemplate {
  id           String   @id @default(cuid())
  locationId   String
  name         String
  title        String
  jobType      String
  leadSource   String?
  tags         String[] @default([])
  privateNotes String?
  lineItems    Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, name])
  @@index([locationId])
}

model ServicePlanTemplate {
  id                  String   @id @default(cuid())
  locationId          String
  name                String
  description         String?
  businessUnit        String?
  visitsPerYear       Int      @default(1)
  durationType        String   @default("indefinite")
  billingInterval     String   @default("yearly")
  recurringAmount     Int      @default(0)
  cashAllowed         Boolean  @default(false)
  discountDescription String?
  discountPercent     Int?
  addOns              Json?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  location            Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, name])
  @@index([locationId, active])
}

model PriceBookCategory {
  id          String          @id @default(cuid())
  locationId  String
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  location    Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  items       PriceBookItem[]

  @@unique([locationId, name])
}

model PriceBookItem {
  id              String             @id @default(cuid())
  locationId      String
  categoryId      String?
  name            String
  modelNumber     String?
  itemType        String             @default("service")
  description     String?
  price           Int                @default(0)
  cost            Int                @default(0)
  taxable         Boolean            @default(true)
  onlineBooking   Boolean            @default(false)
  imageName       String?
  active          Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  location        Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  category        PriceBookCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([locationId, itemType])
  @@index([locationId, categoryId])
}

model JobNote {
  id        String   @id @default(cuid())
  jobId     String
  author    String
  content   String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobLineItem {
  id          String   @id @default(cuid())
  jobId       String
  category    String   @default("service")
  name        String
  description String?
  quantity    Decimal  @default(1)
  unitPrice   Int      @default(0)
  unitCost    Int      @default(0)
  taxable     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Invoice {
  id                    String        @id @default(cuid())
  invoiceNumber         Int           @unique @default(autoincrement())
  locationId            String
  customerId            String
  jobId                 String?
  status                InvoiceStatus @default(DRAFT)
  subtotal              Int           @default(0)
  tax                   Int           @default(0)
  total                 Int           @default(0)
  dueAt                 DateTime?
  stripePaymentIntentId String?
  housecallProId        String?       @unique
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  customer              Customer      @relation(fields: [customerId], references: [id])
  job                   Job?          @relation(fields: [jobId], references: [id])
  location              Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  items                 InvoiceItem[]
  payments              Payment[]
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  category    String   @default("service")
  name        String
  description String?
  quantity    Decimal  @default(1)
  unitPrice   Int      @default(0)
  taxable     Boolean  @default(true)
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String
  amount          Int
  status          PaymentStatus @default(PENDING)
  provider        String        @default("stripe")
  providerRef     String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
}

model Message {
  id          String           @id @default(cuid())
  locationId  String?
  customerId  String?
  jobId       String?
  invoiceId   String?
  direction   MessageDirection
  fromNumber  String
  toNumber    String
  body        String
  channel     String           @default("sms")
  status      String           @default("SENT")
  error       String?
  templateKey String?
  attachments String[]         @default([])
  provider    String           @default("voipms")
  providerRef String?
  createdAt   DateTime         @default(now())
  customer    Customer?        @relation(fields: [customerId], references: [id])
  location    Location?        @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, customerId, createdAt])
  @@index([jobId])
  @@index([invoiceId])
}

model IntegrationCredential {
  id             String        @id @default(cuid())
  organizationId String?
  locationId     String?
  provider       String
  enabled        Boolean       @default(false)
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location       Location?     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, provider])
}
